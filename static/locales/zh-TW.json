  "prompts.meta.core_distill.label": "核心記憶提煉 (Core Distillation)",
  "prompts.meta.core_distill.description": "從情境記憶中提煉使用者的人物側寫與深層特徵。",
  "prompts.meta.core_fusion.label": "核心記憶融合 (Core Fusion)",
  "prompts.meta.core_fusion.description": "融合兩筆相似的核心記憶為單一事實。",
  "prompts.meta.dialogue_compress.label": "對話壓縮 (Dialogue Compression)",
  "prompts.meta.dialogue_compress.description": "將舊對話壓縮為客觀事件摘要（單次對話級別）。",
  "prompts.meta.emotional_trajectory_block.label": "情緒軌跡區塊 (Emotional Trajectory Block)",
  "prompts.meta.emotional_trajectory_block.description": "注入上一輪的情緒狀態，幫助 LLM 維持角色情緒節奏的連貫性。無前輪紀錄時省略整個區塊。",
  "prompts.meta.environment_context_block.label": "環境上下文區塊 (Environment Context Block)",
  "prompts.meta.environment_context_block.description": "注入在使用者訊息前的動態環境資訊（時間、SU private face 天氣）。放在 user message 前綴而非 system prompt，避免破壞 prefix cache。",
  "prompts.meta.episodic_overview.label": "情境概覽生成 (Episodic Overview)",
  "prompts.meta.episodic_overview.description": "將合併後的歷史對話總結為單一情境概覽。",
  "prompts.meta.group_followup_user.label": "群組接力指令 (Group Follow-up User Instruction)",
  "prompts.meta.group_followup_user.description": "Bot-to-bot 接力時暫時追加為最後一則 user control，不寫入對話資料庫。",
  "prompts.meta.group_participants_block.label": "群組成員資訊 (Group Participants Block)",
  "prompts.meta.group_participants_block.description": "多 AI 群組對話中注入最終 chat system prompt 的成員名冊，協助各角色知道彼此存在。",
  "prompts.meta.group_router_system.label": "群組對話發話路由器 (Group Router)",
  "prompts.meta.group_router_system.description": "根據近期群組上下文決定下一位應該發話的 AI 角色，或停止等待使用者。",
  "prompts.meta.history_compress.label": "歷史記憶編年史化 (History Compression)",
  "prompts.meta.history_compress.description": "將多段歷史對話按時間段壓縮為編年史（整合級別）。",
  "prompts.meta.memory_pipeline.label": "記憶管線 (Memory Pipeline)",
  "prompts.meta.memory_pipeline.description": "將最新對話提煉為結構化記憶區塊。",
  "prompts.meta.opening_penalty_instruction.label": "開場白短期抑制 (Opening Penalty Instruction)",
  "prompts.meta.opening_penalty_instruction.description": "角色近期 reply 開頭重複時，附加到最後一則 user control 的動態限制。",
  "prompts.meta.opening_penalty_retry.label": "開場白抑制重試 (Opening Penalty Retry)",
  "prompts.meta.opening_penalty_retry.description": "模型仍以被抑制開場起手時，附加到最後一則 user control 的一次性重試指令。",
  "prompts.meta.query_expand.label": "查詢擴展 (Query Expansion)",
  "prompts.meta.query_expand.description": "將使用者的最新提問擴展為檢索標籤，用於記憶向量搜尋。",
  "prompts.meta.router_system.label": "意圖路由代理 (Router Agent)",
  "prompts.meta.router_system.description": "分析使用者意圖，判斷是否需要呼叫外部工具。只呼叫工具，不輸出文字。",
  "prompts.meta.tool_thinking_speech.label": "工具等待語 (Tool Thinking Speech)",
  "prompts.meta.tool_thinking_speech.description": "工具路由觸發後立即推播的過渡語音。{char_name} 為角色名稱。",
  "prompts.meta.tts_speech_translate.label": "TTS 語音翻譯 (TTS Speech Translation)",
  "prompts.meta.tts_speech_translate.description": "獨立 TTS 翻譯 subagent：將 reply 精確翻譯為指定語言的朗讀文本，不依賴主對話 LLM。",
  "prompts.meta.user_facts_extract.label": "使用者事實提取 (User Facts Extraction)",
  "prompts.meta.user_facts_extract.description": "從對話中提取使用者的客觀事實與明確宣告。",
  "prompts.meta.user_identity_block.label": "使用者身份區塊 (User Identity Block)",
  "prompts.meta.user_identity_block.description": "注入在最新使用者訊息前的暫態真人顯示名稱；不寫入對話資料庫，不包含後端 ID 類 metadata 或額外行為指令。",
